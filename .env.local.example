# ─── Email (Resend) ────────────────────────────────────────────────────────────
#
# Sign up free at https://resend.com — 3,000 emails/month on the free plan.
# Add your API key and the forms will send real emails.
# Without this key, submissions are only logged to the server console.
#
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "from" address shown in outgoing emails.
# With a free Resend account, use: onboarding@resend.dev
# With a verified domain, use something like: DHJ Contact <hello@yourdomain.com>
FROM_EMAIL=DHJ Contact <onboarding@resend.dev>

# Where contact and apply submissions are delivered.
CONTACT_EMAIL=simplymusic@verizon.net
